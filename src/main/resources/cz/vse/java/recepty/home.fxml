<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="400.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="cz.vse.java.recepty.HomeController">

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;">
            <VBox spacing="15" style="-fx-padding: 20;">

                <Label fx:id="helloLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Are you ready to fulfill your goals?" style="-fx-text-fill: gray;"/>

                <Label fx:id="goalLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>

                <Label text="Daily Targets" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <VBox fx:id="targetsMatrixContainer" alignment="CENTER"/>

                <Label text="Daily Progress" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <VBox fx:id="progressMatrixContainer" alignment="CENTER"/>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Recipes for you" style="-fx-font-weight: bold; -fx-font-size: 18px;"/>
                    <Button text="Filter" style="-fx-background-color: #e0e0e0;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="10">
                    <Button fx:id="btnBreakfast" text="Breakfast" onAction="#showBreakfast" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                    <Button fx:id="btnLunch" text="Lunch" onAction="#showLunch" style="-fx-background-color: transparent; -fx-border-color: #ccc;"/>
                    <Button fx:id="btnDinner" text="Dinner" onAction="#showDinner" style="-fx-background-color: transparent; -fx-border-color: #ccc;"/>
                </HBox>

                <VBox fx:id="recipesContainer" spacing="15"/>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #f8f8f8; -fx-padding: 15; -fx-border-color: #ccc; -fx-border-width: 1 0 0 0;">
            <Button text="Home" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            <Button text="My Recipes" onAction="#handleMyRecipes" style="-fx-background-color: transparent;"/>
            <Button text="Search" onAction="#handleSearch" style="-fx-background-color: transparent;"/>
            <Button text="Options" onAction="#handleOptions" style="-fx-background-color: transparent;"/>
        </HBox>
    </bottom>

</BorderPane>

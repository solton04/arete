<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="400.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="cz.vse.java.recepty.SearchController">

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0;">
            <VBox spacing="15" style="-fx-padding: 20;">

                <Label text="Search Recipes" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

                <TextField fx:id="searchField" promptText="Enter recipe name..." onKeyReleased="#handleSearchType"/>

                <VBox fx:id="recipesContainer" spacing="15"/>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-background-color: #f8f8f8; -fx-padding: 15; -fx-border-color: #ccc; -fx-border-width: 1 0 0 0;">
            <Button text="Home" onAction="#handleHome" style="-fx-background-color: transparent;"/>
            <Button text="My Recipes" onAction="#handleMyRecipes" style="-fx-background-color: transparent;"/>
            <Button text="Search" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            <Button text="Options" onAction="#handleOptions" style="-fx-background-color: transparent;"/>
        </HBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" prefHeight="800.0" prefWidth="400.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="cz.vse.java.recepty.ProfileStep4Controller">

    <Label text="Step 4 of 5" style="-fx-text-fill: gray;"/>
    <Label text="Your Goal" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <ComboBox fx:id="goalCombo" maxWidth="300" promptText="Select your goal"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;" maxWidth="300" wrapText="true"/>

    <Button text="Calculate Targets" onAction="#handleNext" maxWidth="300" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    <Button text="Back" onAction="#handleBack" maxWidth="300"/>

</VBox>

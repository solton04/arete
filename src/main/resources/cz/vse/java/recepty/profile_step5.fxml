<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" prefHeight="800.0" prefWidth="400.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="cz.vse.java.recepty.ProfileStep5Controller">

    <Label text="Step 5 of 5" style="-fx-text-fill: gray;"/>
    <Label text="Your Daily Targets" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox fx:id="matrixContainer" alignment="CENTER" spacing="10" />

    <VBox alignment="CENTER_LEFT" maxWidth="300" spacing="10" style="-fx-background-color: #f0f0f0; -fx-padding: 15; -fx-background-radius: 10;">
        <Label text="Key Wellness Tips" style="-fx-font-weight: bold;"/>
        <Label text="- Drink at least 2 liters of water daily" wrapText="true"/>
        <Label text="- Avoid eating after 8 pm" wrapText="true"/>
        <Label text="- Get 7-8 hours of sleep" wrapText="true"/>
        <Label text="- Stay consistent with your exercise routine" wrapText="true"/>
    </VBox>

    <Button text="Let's start!" onAction="#handleStart" maxWidth="300"
            style="-fx-background-color: #43927D; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 10;"/>
    <Button text="Back" onAction="#handleBack" maxWidth="300"
            style="-fx-background-radius: 15"/>

</VBox>

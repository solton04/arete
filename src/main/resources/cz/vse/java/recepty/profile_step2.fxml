<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" prefHeight="800.0" prefWidth="400.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="cz.vse.java.recepty.ProfileStep2Controller">

    <Label text="Step 2 of 5" style="-fx-text-fill: gray;"/>
    <Label text="Body Metrics" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TextField fx:id="weightField" promptText="Weight (kg)" maxWidth="300"/>
    <TextField fx:id="heightField" promptText="Height (cm)" maxWidth="300"/>

    <Button text="Next" onAction="#handleNext" maxWidth="300" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    <Button text="Back" onAction="#handleBack" maxWidth="300"/>

</VBox>
